# Número de WhatsApp usado em todos os botões/links "Falar no WhatsApp" do site.
# Formato: código do país + DDD + número, SOMENTE DÍGITOS (sem espaços, +, (), -).
# Exemplo para (91) 97400-9540 => 5591974009540
NEXT_PUBLIC_WHATSAPP_DIGITS=5591974009540

# Como o número de WhatsApp aparece formatado na tela (rodapé, página de contato etc.)
NEXT_PUBLIC_WHATSAPP_DISPLAY=(91) 97400-9540

# Número de telefone fixo usado nos links "tel:" (ligar).
# Formato: +código do país + DDD + número, sem espaços.
NEXT_PUBLIC_PHONE_DIGITS=+5591335353053

# Como o telefone fixo aparece formatado na tela.
NEXT_PUBLIC_PHONE_DISPLAY=(91) 3353-3053
